/*
 * JIT-specialized CPU fused scan+elem kernel.
 *
 * Compile-time constants:
 *   SIMD={{ SIMD }}, D_INNER={{ D_INNER }}, D_STATE={{ D_STATE }}
 *   L3_TILE_SIZE={{ L3_TILE_SIZE }}
 *   PREFETCH_DISTANCE={{ PREFETCH_DISTANCE }}
 *   OMP_THREADS={{ OMP_THREADS }}
 *   NUMA_AWARE={{ NUMA_AWARE }}
 *
 * Generated by grokking_optimizers/jit/cpu_specializer.py
 */

#include <torch/extension.h>
#include <cmath>
#include <algorithm>

{% if HAS_AVX512 %}
#include <immintrin.h>
{% elif HAS_AVX2 %}
#include <immintrin.h>
{% elif HAS_NEON %}
#include <arm_neon.h>
{% endif %}

#define JIT_D_INNER {{ D_INNER }}
#define JIT_D_STATE {{ D_STATE }}
#define JIT_L3_TILE {{ L3_TILE_SIZE }}
#define JIT_PREFETCH {{ PREFETCH_DISTANCE }}
#define JIT_OMP_THREADS {{ OMP_THREADS }}

// Inline affine combine (C++ version, same math as PTX)
static inline void affine_combine_cpu(
    float& n00, float& n01, float& n10, float& n11, float& nb0, float& nb1,
    float m00, float m01, float m10, float m11, float b0, float b1,
    float r00, float r01, float r10, float r11, float rb0, float rb1
) {
    n00 = r00 * m00 + r01 * m10;
    n01 = r00 * m01 + r01 * m11;
    n10 = r10 * m00 + r11 * m10;
    n11 = r10 * m01 + r11 * m11;
    nb0 = r00 * b0 + r01 * b1 + rb0;
    nb1 = r10 * b0 + r11 * b1 + rb1;
}

{% if SIMD == 'avx512' %}
// AVX-512 vectorized Adam update (16 elements per iteration)
static inline void adam_update_avx512(
    float* __restrict__ param,
    const float* __restrict__ grad,
    float* __restrict__ exp_avg,
    float* __restrict__ exp_avg_sq,
    int N,
    float lr, float beta1, float beta2, float eps, float wd,
    float bc1, float bc2
) {
    __m512 v_beta1 = _mm512_set1_ps(beta1);
    __m512 v_1mb1 = _mm512_set1_ps(1.0f - beta1);
    __m512 v_beta2 = _mm512_set1_ps(beta2);
    __m512 v_1mb2 = _mm512_set1_ps(1.0f - beta2);
    __m512 v_lr = _mm512_set1_ps(lr);
    __m512 v_eps = _mm512_set1_ps(eps);
    __m512 v_wd = _mm512_set1_ps(wd);
    __m512 v_bc1 = _mm512_set1_ps(bc1);
    __m512 v_bc2 = _mm512_set1_ps(bc2);

    int i = 0;
    for (; i + 16 <= N; i += 16) {
        // Prefetch next cache line
        {% if PREFETCH_DISTANCE > 0 %}
        _mm_prefetch(&param[i + JIT_PREFETCH], _MM_HINT_T0);
        _mm_prefetch(&exp_avg[i + JIT_PREFETCH], _MM_HINT_T0);
        _mm_prefetch(&exp_avg_sq[i + JIT_PREFETCH], _MM_HINT_T0);
        {% endif %}

        __m512 p = _mm512_loadu_ps(&param[i]);
        __m512 g = _mm512_loadu_ps(&grad[i]);
        __m512 m = _mm512_loadu_ps(&exp_avg[i]);
        __m512 v = _mm512_loadu_ps(&exp_avg_sq[i]);

        // m = beta1 * m + (1-beta1) * g
        m = _mm512_fmadd_ps(v_beta1, m, _mm512_mul_ps(v_1mb1, g));
        // v = beta2 * v + (1-beta2) * g^2
        v = _mm512_fmadd_ps(v_beta2, v, _mm512_mul_ps(v_1mb2, _mm512_mul_ps(g, g)));
        // p -= lr * (m_hat / (sqrt(v_hat) + eps) + wd * p)
        __m512 m_hat = _mm512_mul_ps(m, v_bc1);
        __m512 v_hat = _mm512_mul_ps(v, v_bc2);
        __m512 denom = _mm512_add_ps(_mm512_sqrt_ps(v_hat), v_eps);
        __m512 update = _mm512_add_ps(_mm512_div_ps(m_hat, denom), _mm512_mul_ps(v_wd, p));
        p = _mm512_fnmadd_ps(v_lr, update, p);

        _mm512_storeu_ps(&param[i], p);
        _mm512_storeu_ps(&exp_avg[i], m);
        _mm512_storeu_ps(&exp_avg_sq[i], v);
    }
    // Scalar tail
    for (; i < N; i++) {
        float m = beta1 * exp_avg[i] + (1.0f - beta1) * grad[i];
        float v = beta2 * exp_avg_sq[i] + (1.0f - beta2) * grad[i] * grad[i];
        float m_hat = m * bc1;
        float v_hat = v * bc2;
        param[i] -= lr * (m_hat / (sqrtf(v_hat) + eps) + wd * param[i]);
        exp_avg[i] = m;
        exp_avg_sq[i] = v;
    }
}
{% elif SIMD == 'avx2' %}
// AVX2 vectorized Adam update (8 elements per iteration)
static inline void adam_update_avx2(
    float* __restrict__ param,
    const float* __restrict__ grad,
    float* __restrict__ exp_avg,
    float* __restrict__ exp_avg_sq,
    int N,
    float lr, float beta1, float beta2, float eps, float wd,
    float bc1, float bc2
) {
    __m256 v_beta1 = _mm256_set1_ps(beta1);
    __m256 v_1mb1 = _mm256_set1_ps(1.0f - beta1);
    __m256 v_beta2 = _mm256_set1_ps(beta2);
    __m256 v_1mb2 = _mm256_set1_ps(1.0f - beta2);
    __m256 v_lr = _mm256_set1_ps(lr);
    __m256 v_eps = _mm256_set1_ps(eps);
    __m256 v_wd = _mm256_set1_ps(wd);
    __m256 v_bc1 = _mm256_set1_ps(bc1);
    __m256 v_bc2 = _mm256_set1_ps(bc2);

    int i = 0;
    for (; i + 8 <= N; i += 8) {
        __m256 p = _mm256_loadu_ps(&param[i]);
        __m256 g = _mm256_loadu_ps(&grad[i]);
        __m256 m = _mm256_loadu_ps(&exp_avg[i]);
        __m256 v = _mm256_loadu_ps(&exp_avg_sq[i]);

        m = _mm256_fmadd_ps(v_beta1, m, _mm256_mul_ps(v_1mb1, g));
        v = _mm256_fmadd_ps(v_beta2, v, _mm256_mul_ps(v_1mb2, _mm256_mul_ps(g, g)));
        __m256 m_hat = _mm256_mul_ps(m, v_bc1);
        __m256 v_hat = _mm256_mul_ps(v, v_bc2);
        __m256 denom = _mm256_add_ps(_mm256_sqrt_ps(v_hat), v_eps);
        __m256 update = _mm256_add_ps(_mm256_div_ps(m_hat, denom), _mm256_mul_ps(v_wd, p));
        p = _mm256_fnmadd_ps(v_lr, update, p);

        _mm256_storeu_ps(&param[i], p);
        _mm256_storeu_ps(&exp_avg[i], m);
        _mm256_storeu_ps(&exp_avg_sq[i], v);
    }
    for (; i < N; i++) {
        float m = beta1 * exp_avg[i] + (1.0f - beta1) * grad[i];
        float v = beta2 * exp_avg_sq[i] + (1.0f - beta2) * grad[i] * grad[i];
        param[i] -= lr * (m * bc1 / (sqrtf(v * bc2) + eps) + wd * param[i]);
        exp_avg[i] = m;
        exp_avg_sq[i] = v;
    }
}
{% endif %}

// Main entry point: L3-tiled fused scan + elem
void jit_cpu_fused_scan_elem(
    torch::Tensor param,
    torch::Tensor grad,
    torch::Tensor exp_avg,
    torch::Tensor exp_avg_sq,
    torch::Tensor gru_state,
    torch::Tensor scan_output,
    float lr, float beta1, float beta2, float eps, float wd,
    float bc1, float bc2
) {
    const int N = param.numel();
    float* p_ptr = param.data_ptr<float>();
    const float* g_ptr = grad.data_ptr<float>();
    float* ea_ptr = exp_avg.data_ptr<float>();
    float* eas_ptr = exp_avg_sq.data_ptr<float>();

    // Process in L3-sized tiles for cache efficiency
    #pragma omp parallel for num_threads(JIT_OMP_THREADS) schedule(static)
    for (int tile = 0; tile < N; tile += JIT_L3_TILE) {
        int tile_end = std::min(tile + JIT_L3_TILE, N);
        int tile_size = tile_end - tile;

        {% if SIMD == 'avx512' %}
        adam_update_avx512(
            p_ptr + tile, g_ptr + tile, ea_ptr + tile, eas_ptr + tile,
            tile_size, lr, beta1, beta2, eps, wd, bc1, bc2
        );
        {% elif SIMD == 'avx2' %}
        adam_update_avx2(
            p_ptr + tile, g_ptr + tile, ea_ptr + tile, eas_ptr + tile,
            tile_size, lr, beta1, beta2, eps, wd, bc1, bc2
        );
        {% else %}
        // Scalar fallback
        for (int i = 0; i < tile_size; i++) {
            int idx = tile + i;
            float m = beta1 * ea_ptr[idx] + (1.0f - beta1) * g_ptr[idx];
            float v = beta2 * eas_ptr[idx] + (1.0f - beta2) * g_ptr[idx] * g_ptr[idx];
            float m_hat = m * bc1;
            float v_hat = v * bc2;
            p_ptr[idx] -= lr * (m_hat / (sqrtf(v_hat) + eps) + wd * p_ptr[idx]);
            ea_ptr[idx] = m;
            eas_ptr[idx] = v;
        }
        {% endif %}
    }
}

PYBIND11_MODULE(TORCH_EXTENSION_NAME, m) {
    m.def("jit_cpu_fused_scan_elem", &jit_cpu_fused_scan_elem,
          "JIT CPU fused scan+elem ({{ SIMD }}, L3 tile={{ L3_TILE_SIZE }})");
}
