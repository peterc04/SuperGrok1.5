/*
 * JIT-specialized fused element-wise step kernel.
 *
 * Fuses: GRU gate + PEER expert routing + Expert MLP + Adam update
 * into a single kernel launch with expert weights in shared memory.
 *
 * Compile-time constants:
 *   D_INNER={{ D_INNER }}, NUM_EXPERTS={{ NUM_EXPERTS }}
 *   EXPERT_HIDDEN={{ EXPERT_HIDDEN }}, GRU_HIDDEN={{ GRU_HIDDEN }}
 *   ELEM_BLOCK_SIZE={{ ELEM_BLOCK_SIZE }}
 *   SMEM_PADDING={{ SMEM_PADDING }}
 *   SM_VERSION={{ SM_VERSION }}
 *
 * Generated by grokking_optimizers/jit/cuda_specializer.py
 */

#include <cuda_runtime.h>
#include <math.h>

#define JIT_NUM_EXPERTS {{ NUM_EXPERTS }}
#define JIT_EXPERT_HIDDEN {{ EXPERT_HIDDEN }}
#define JIT_GRU_HIDDEN {{ GRU_HIDDEN }}
#define JIT_ELEM_BLOCK {{ ELEM_BLOCK_SIZE }}
#define JIT_SMEM_PAD {{ SMEM_PADDING }}

// Expert hidden + padding to avoid bank conflicts
#define JIT_EH_PADDED (JIT_EXPERT_HIDDEN + JIT_SMEM_PAD)

// Total shared memory for all meta-net weights
#define JIT_SMEM_EXPERT_W1  (JIT_NUM_EXPERTS * JIT_EH_PADDED * 3)
#define JIT_SMEM_EXPERT_B1  (JIT_NUM_EXPERTS * JIT_EH_PADDED)
#define JIT_SMEM_EXPERT_W2  (JIT_NUM_EXPERTS * JIT_EH_PADDED)
#define JIT_SMEM_EXPERT_B2  (JIT_NUM_EXPERTS)
#define JIT_SMEM_GRU        (JIT_GRU_HIDDEN * 6)

#define JIT_TOTAL_SMEM_FLOATS (JIT_SMEM_EXPERT_W1 + JIT_SMEM_EXPERT_B1 + \
                               JIT_SMEM_EXPERT_W2 + JIT_SMEM_EXPERT_B2 + \
                               JIT_SMEM_GRU)

// Expert MLP (unrolled if expert_hidden matches known size)
__device__ __forceinline__ float jit_expert_mlp(
    const float* smem_W1, const float* smem_b1,
    const float* smem_W2, const float* smem_b2,
    float in0, float in1, int expert_idx
) {
    const float* W1 = smem_W1 + expert_idx * JIT_EH_PADDED * 3;
    const float* b1 = smem_b1 + expert_idx * JIT_EH_PADDED;
    const float* W2 = smem_W2 + expert_idx * JIT_EH_PADDED;
    float b2_val = smem_b2[expert_idx];

    float accum = b2_val;
    #pragma unroll
    for (int i = 0; i < JIT_EXPERT_HIDDEN; i++) {
        float h = W1[i * 3 + 0] * in0 + W1[i * 3 + 1] * in1 + b1[i];
        // Approximate GELU
        h = h * (1.0f / (1.0f + __expf(-1.702f * h)));
        accum += W2[i] * h;
    }
    return accum;
}

__launch_bounds__(JIT_ELEM_BLOCK, {{ LAUNCH_MIN_BLOCKS_ELEM }})
__global__ void jit_fused_elem_step_kernel(
    float* __restrict__ param,
    const float* __restrict__ grad,
    const float* __restrict__ scan_output,
    float* __restrict__ exp_avg,
    float* __restrict__ exp_avg_sq,
    float* __restrict__ gru_state,
    // Meta-net weights (loaded into smem)
    const float* __restrict__ expert_W1,
    const float* __restrict__ expert_b1,
    const float* __restrict__ expert_W2,
    const float* __restrict__ expert_b2,
    const float* __restrict__ gru_Wz,
    const float* __restrict__ gru_bz,
    const float* __restrict__ gru_Wr,
    const float* __restrict__ gru_br,
    const float* __restrict__ gru_Wh,
    const float* __restrict__ gru_bh,
    // Config
    int N,
    float lr, float beta1, float beta2, float eps, float wd,
    float bc1, float bc2, float rescale
) {
    extern __shared__ float smem[];

    // Cooperative shared memory load
    float* smem_W1 = smem;
    float* smem_b1 = smem_W1 + JIT_SMEM_EXPERT_W1;
    float* smem_W2 = smem_b1 + JIT_SMEM_EXPERT_B1;
    float* smem_b2 = smem_W2 + JIT_SMEM_EXPERT_W2;
    float* smem_gru = smem_b2 + JIT_SMEM_EXPERT_B2;

    // Load expert weights into shared memory (all threads cooperate)
    for (int i = threadIdx.x; i < JIT_SMEM_EXPERT_W1; i += JIT_ELEM_BLOCK)
        smem_W1[i] = expert_W1[i];
    for (int i = threadIdx.x; i < JIT_SMEM_EXPERT_B1; i += JIT_ELEM_BLOCK)
        smem_b1[i] = expert_b1[i];
    for (int i = threadIdx.x; i < JIT_SMEM_EXPERT_W2; i += JIT_ELEM_BLOCK)
        smem_W2[i] = expert_W2[i];
    for (int i = threadIdx.x; i < JIT_SMEM_EXPERT_B2; i += JIT_ELEM_BLOCK)
        smem_b2[i] = expert_b2[i];
    // Load GRU weights
    for (int i = threadIdx.x; i < JIT_SMEM_GRU; i += JIT_ELEM_BLOCK) {
        if (i < JIT_GRU_HIDDEN) smem_gru[i] = gru_Wz[i];
        else if (i < 2 * JIT_GRU_HIDDEN) smem_gru[i] = gru_bz[i - JIT_GRU_HIDDEN];
        else if (i < 3 * JIT_GRU_HIDDEN) smem_gru[i] = gru_Wr[i - 2 * JIT_GRU_HIDDEN];
        else if (i < 4 * JIT_GRU_HIDDEN) smem_gru[i] = gru_br[i - 3 * JIT_GRU_HIDDEN];
        else if (i < 5 * JIT_GRU_HIDDEN) smem_gru[i] = gru_Wh[i - 4 * JIT_GRU_HIDDEN];
        else smem_gru[i] = gru_bh[i - 5 * JIT_GRU_HIDDEN];
    }
    __syncthreads();

    // Each thread processes one parameter element
    int idx = blockIdx.x * blockDim.x + threadIdx.x;
    if (idx >= N) return;

    // Load optimizer state (non-temporal if possible)
    float p = param[idx];
    float g = grad[idx];
    float scan_out = scan_output[idx];
    float ea = exp_avg[idx];
    float eas = exp_avg_sq[idx];
    float gs = gru_state[idx];

    // GRU gate (simplified: single-element input)
    float gru_input = g * scan_out;
    float z_gate = 1.0f / (1.0f + __expf(-(smem_gru[0] * gru_input + smem_gru[JIT_GRU_HIDDEN])));
    float r_gate = 1.0f / (1.0f + __expf(-(smem_gru[2 * JIT_GRU_HIDDEN] * gru_input + smem_gru[3 * JIT_GRU_HIDDEN])));
    float h_candidate = tanhf(smem_gru[4 * JIT_GRU_HIDDEN] * (r_gate * gs) + smem_gru[5 * JIT_GRU_HIDDEN]);
    float new_gs = (1.0f - z_gate) * gs + z_gate * h_candidate;

    // PEER routing (simplified: use scan output as routing signal)
    int expert_idx = (int)(fabsf(scan_out) * JIT_NUM_EXPERTS) % JIT_NUM_EXPERTS;

    // Expert MLP
    float expert_out = jit_expert_mlp(smem_W1, smem_b1, smem_W2, smem_b2,
                                       g, scan_out, expert_idx);

    // Smart gradient = base grad + rescaled expert output
    float smart_grad = g + rescale * expert_out;

    // Adam update with bias correction
    ea = beta1 * ea + (1.0f - beta1) * smart_grad;
    eas = beta2 * eas + (1.0f - beta2) * smart_grad * smart_grad;
    float ea_hat = ea * bc1;
    float eas_hat = eas * bc2;
    float update = ea_hat / (sqrtf(eas_hat) + eps);
    p = p - lr * (update + wd * p);

    // Store (non-temporal for optimizer state)
    param[idx] = p;
    exp_avg[idx] = ea;
    exp_avg_sq[idx] = eas;
    gru_state[idx] = new_gs;
}
