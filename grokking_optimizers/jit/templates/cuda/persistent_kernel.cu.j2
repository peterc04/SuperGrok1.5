/*
 * JIT-specialized persistent scan+elem kernel.
 *
 * Single kernel launch that processes scan + fused_elem in one pass.
 * Each thread block is persistent (one per SM), processing multiple
 * parameter groups without returning to the CPU.
 *
 * Compile-time constants:
 *   D_INNER={{ D_INNER }}, D_STATE={{ D_STATE }}
 *   NUM_EXPERTS={{ NUM_EXPERTS }}, EXPERT_HIDDEN={{ EXPERT_HIDDEN }}
 *   SM_VERSION={{ SM_VERSION }}, L2_CACHE_SIZE={{ L2_CACHE_SIZE }}
 *
 * Generated by grokking_optimizers/jit/cuda_specializer.py
 */

#include <cuda_runtime.h>
#include <math.h>

// L2 cache-aware tile size: process elements in L2-sized tiles
// to maximize L2 hit rate for optimizer state arrays
#define JIT_L2_TILE_ELEMS ({{ L2_CACHE_SIZE }} / (5 * 4) / 4)  // 5 state arrays, div by 4 for ~25% L2 budget

__launch_bounds__({{ ELEM_BLOCK_SIZE }}, 1)
__global__ void jit_persistent_scan_elem_kernel(
    // Parameter groups (array of pointers)
    float** __restrict__ params,
    float** __restrict__ grads,
    float** __restrict__ exp_avgs,
    float** __restrict__ exp_avg_sqs,
    float** __restrict__ gru_states,
    const int* __restrict__ param_sizes,
    int num_param_groups,
    // Scan state
    const float* __restrict__ A_log,
    const float* __restrict__ D_param,
    // Meta-net weights
    const float* __restrict__ expert_W1,
    const float* __restrict__ expert_b1,
    const float* __restrict__ expert_W2,
    const float* __restrict__ expert_b2,
    const float* __restrict__ gru_weights,
    // Hyperparameters
    float lr, float beta1, float beta2, float eps, float wd,
    float bc1, float bc2, float rescale
) {
    // Persistent kernel: each block processes all param groups
    // Block 0 processes groups 0, num_blocks, 2*num_blocks, ...
    // Block 1 processes groups 1, num_blocks+1, ...
    extern __shared__ float smem[];

    int block_id = blockIdx.x;
    int num_blocks = gridDim.x;

    // Load expert weights into shared memory once
    // (reused across all parameter groups)
    int total_expert_weights = {{ NUM_EXPERTS }} * {{ EXPERT_HIDDEN }} * 3;
    #pragma unroll 4
    for (int i = threadIdx.x; i < total_expert_weights; i += blockDim.x) {
        smem[i] = expert_W1[i];
    }
    __syncthreads();

    // Process parameter groups assigned to this block
    for (int pg = block_id; pg < num_param_groups; pg += num_blocks) {
        int N = param_sizes[pg];
        float* param = params[pg];
        float* grad = grads[pg];
        float* ea = exp_avgs[pg];
        float* eas = exp_avg_sqs[pg];
        float* gs = gru_states[pg];

        // Process in L2-sized tiles
        for (int tile_start = 0; tile_start < N; tile_start += JIT_L2_TILE_ELEMS) {
            int tile_end = min(tile_start + JIT_L2_TILE_ELEMS, N);

            for (int idx = tile_start + threadIdx.x; idx < tile_end; idx += blockDim.x) {
                float p = param[idx];
                float g = grad[idx];
                float m = ea[idx];
                float v = eas[idx];

                // Adam update
                m = beta1 * m + (1.0f - beta1) * g;
                v = beta2 * v + (1.0f - beta2) * g * g;
                float m_hat = m * bc1;
                float v_hat = v * bc2;
                p = p - lr * (m_hat / (sqrtf(v_hat) + eps) + wd * p);

                param[idx] = p;
                ea[idx] = m;
                eas[idx] = v;
            }
        }
    }
}
