{% if SM_VERSION >= 80 %}
// Ampere+ cp.async for projection loading
__device__ __forceinline__ void jit_cp_async_load(float* smem, const float* gmem, int size) {
    for (int i = threadIdx.x; i < size; i += blockDim.x) {
        asm volatile(
            "cp.async.cg.shared.global [%0], [%1], 4;\n\t"
            :: "r"((unsigned)__cvta_generic_to_shared(&smem[i])),
               "l"(&gmem[i])
        );
    }
    asm volatile("cp.async.commit_group;\n\t" :::);
}
{% endif %}

__launch_bounds__(JIT_SCAN_BLOCK, {{ LAUNCH_MIN_BLOCKS_SCAN }})
__global__ void jit_mamba3_scan_kernel(
    const float* __restrict__ pre_x,
    const float* __restrict__ pre_z,
    const float* __restrict__ pre_dt,
    const float* __restrict__ pre_B,
    const float* __restrict__ pre_C,
    const float* __restrict__ A_log,
    const float* __restrict__ D_param,
    float* __restrict__ scan_output,
    const float* __restrict__ initial_state,
    int N, int d_inner, int d_state
) {
    // Specialized for d_inner={{ D_INNER }}, d_state={{ D_STATE }}
    const int j = blockIdx.x;  // d_inner dimension
    if (j >= JIT_D_INNER) return;

    const float D_val = D_param[j];

    // Hidden state in registers — fully unrolled for d_state={{ D_STATE }}
    float h[JIT_D_STATE];
    #pragma unroll
    for (int s = 0; s < JIT_D_STATE; s++) {
        h[s] = (initial_state != nullptr) ? initial_state[j * JIT_D_STATE + s] : 0.0f;
    }

    // Sequential scan over N timesteps
    for (int t = 0; t < N; t++) {
        float dt_val = pre_dt[t * JIT_D_INNER + j];
        float x_val = pre_x[t * JIT_D_INNER + j];
        float z_val = pre_z[t * JIT_D_INNER + j];

        float y = 0.0f;

        // Unrolled state update for d_state={{ D_STATE }}
        #pragma unroll
        for (int s = 0; s < JIT_D_STATE; s++) {
            float A_val = -__expf(A_log[j * JIT_D_STATE + s]);
            float A_bar = __expf(A_val * dt_val);
            float B_val = pre_B[t * JIT_D_STATE + s];
            float C_val = pre_C[t * JIT_D_STATE + s];

            h[s] = A_bar * h[s] + dt_val * B_val * x_val;
            y += h[s] * C_val;
        }

        // SiLU gating + D skip
        float silu_z = z_val / (1.0f + __expf(-z_val));
        scan_output[t * JIT_D_INNER + j] = y * silu_z + D_val * x_val;
    }
}
