/*
 * JIT-specialized distributed scan kernel.
 *
 * Produces scan output + summary for multi-GPU all-gather,
 * and fused prefix-apply-elem after all-gather completes.
 *
 * Compile-time constants:
 *   D_INNER={{ D_INNER }}, D_STATE={{ D_STATE }}
 *   NUM_EXPERTS={{ NUM_EXPERTS }}, EXPERT_HIDDEN={{ EXPERT_HIDDEN }}
 *   SM_VERSION={{ SM_VERSION }}
 *
 * Generated by grokking_optimizers/jit/cuda_specializer.py
 */

#include <cuda_runtime.h>
#include <math.h>

#define JIT_D_INNER {{ D_INNER }}
#define JIT_D_STATE {{ D_STATE }}
#define JIT_HALF_D_STATE ({{ D_STATE }} / 2)
#define JIT_AFFINE_SIZE 6

// SM-specific PTX for affine combine
__device__ __forceinline__ void jit_dist_affine_combine(
    float& n00, float& n01, float& n10, float& n11, float& nb0, float& nb1,
    float m00, float m01, float m10, float m11, float b0, float b1,
    float r00, float r01, float r10, float r11, float rb0, float rb1
) {
    {{ PTX_AFFINE_COMBINE }}
}

__launch_bounds__(256, {{ LAUNCH_MIN_BLOCKS_SCAN }})
__global__ void jit_distributed_scan_with_summary_kernel(
    const float* __restrict__ pre_x,
    const float* __restrict__ pre_z,
    const float* __restrict__ pre_dt,
    const float* __restrict__ pre_B,
    const float* __restrict__ pre_C,
    const float* __restrict__ A_log,
    const float* __restrict__ D_param,
    const float* __restrict__ rope_freq,
    float* __restrict__ scan_output,
    float* __restrict__ summaries,
    const float* __restrict__ initial_state,
    int N_local, int d_inner, int d_state, int reverse
) {
    const int j = blockIdx.x;
    if (j >= JIT_D_INNER) return;

    const float D_val = D_param[j];
    const int half_d_state = JIT_HALF_D_STATE;

    for (int p = 0; p < half_d_state; p++) {
        int s_e = 2 * p;
        int s_o = 2 * p + 1;
        float A_e = -__expf(A_log[j * JIT_D_STATE + s_e]);
        float A_o = -__expf(A_log[j * JIT_D_STATE + s_o]);
        float freq = rope_freq[j * half_d_state + p];

        // Running affine transform (identity init)
        float rm00 = 1.0f, rm01 = 0.0f, rm10 = 0.0f, rm11 = 1.0f;
        float rb0 = 0.0f, rb1 = 0.0f;

        float h_init_e = (initial_state != nullptr) ? initial_state[j * JIT_D_STATE + s_e] : 0.0f;
        float h_init_o = (initial_state != nullptr) ? initial_state[j * JIT_D_STATE + s_o] : 0.0f;

        for (int step = 0; step < N_local; step++) {
            int t = reverse ? (N_local - 1 - step) : step;
            float dt = pre_dt[t * JIT_D_INNER + j];
            float x_val = pre_x[t * JIT_D_INNER + j];
            float B_e = pre_B[t * JIT_D_STATE + s_e];
            float B_o = pre_B[t * JIT_D_STATE + s_o];

            // Build scan element (Cayley discretization + RoPE)
            float A_bar_e = (1.0f + dt * A_e / 2.0f) / (1.0f - dt * A_e / 2.0f + 1e-8f);
            float A_bar_o = (1.0f + dt * A_o / 2.0f) / (1.0f - dt * A_o / 2.0f + 1e-8f);
            float sin_v, cos_v;
            __sincosf(dt * freq, &sin_v, &cos_v);

            float em00 = A_bar_e * cos_v;
            float em01 = -A_bar_e * sin_v;
            float em10 = A_bar_o * sin_v;
            float em11 = A_bar_o * cos_v;
            float eb0 = dt * B_e * x_val;
            float eb1 = dt * B_o * x_val;

            // Compose: running = elem * running
            float n00, n01, n10, n11, nb0_new, nb1_new;
            jit_dist_affine_combine(n00, n01, n10, n11, nb0_new, nb1_new,
                                     rm00, rm01, rm10, rm11, rb0, rb1,
                                     em00, em01, em10, em11, eb0, eb1);
            rm00 = n00; rm01 = n01; rm10 = n10; rm11 = n11;
            rb0 = nb0_new; rb1 = nb1_new;

            // Compute h and accumulate output
            float h_e = rm00 * h_init_e + rm01 * h_init_o + rb0;
            float h_o = rm10 * h_init_e + rm11 * h_init_o + rb1;
            float C_e = pre_C[t * JIT_D_STATE + s_e];
            float C_o = pre_C[t * JIT_D_STATE + s_o];
            atomicAdd(&scan_output[t * JIT_D_INNER + j], h_e * C_e + h_o * C_o);
        }

        // Store summary (the final running affine transform)
        int sum_idx = (j * half_d_state + p) * JIT_AFFINE_SIZE;
        summaries[sum_idx + 0] = rm00;
        summaries[sum_idx + 1] = rm01;
        summaries[sum_idx + 2] = rm10;
        summaries[sum_idx + 3] = rm11;
        summaries[sum_idx + 4] = rb0;
        summaries[sum_idx + 5] = rb1;
    }

    // Apply SiLU gating and D skip
    for (int t = 0; t < N_local; t++) {
        float z = pre_z[t * JIT_D_INNER + j];
        float silu_z = z / (1.0f + __expf(-z));
        float x_val = pre_x[t * JIT_D_INNER + j];
        int out_idx = t * JIT_D_INNER + j;
        scan_output[out_idx] = scan_output[out_idx] * silu_z + D_val * x_val;
    }
}
